{
    "manifest_version": 3,
    "name": "File Compressor",
    "version": "1.0.0",
    "description": "Compress and decompress PNG, JPEG, text, and video files directly in your browser.",

    "action": {
        "default_popup": "index.html",
        "default_title": "File Compressor"
    },

    "content_security_policy": {
        "extension_pages": "script-src 'self'; object-src 'self'"
    },

    "web_accessible_resources": [
        {
            "resources": [
                "upng.js"
            ],
            "matches": ["<all_urls>"]
        }
    ],

    "permissions": []
}